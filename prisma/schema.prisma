generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  apiKey    String   @unique @map("api_key")
  createdAt DateTime @default(now()) @map("created_at")

  users   User[]
  reports EmailReport[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  email          String   @unique
  hashedPassword String   @map("hashed_password")
  fullName       String?  @map("full_name")
  role           String   @default("viewer")   // "super_admin" | "admin" | "analyst" | "viewer"
  isAdmin        Boolean  @default(false) @map("is_admin")
  isActive       Boolean  @default(true) @map("is_active")
  mfaSecret      String?  @map("mfa_secret")
  mfaEnabled     Boolean  @default(false) @map("mfa_enabled")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization  @relation(fields: [orgId], references: [id])
  actions      AdminAction[]

  @@map("users")
}

model EmailReport {
  id            String    @id @default(cuid())
  orgId         String    @map("org_id")
  reporterEmail String    @map("reporter_email")
  recipientEmail String?  @map("recipient_email")
  subject       String?
  sender        String?
  senderDomain  String?   @map("sender_domain")
  replyTo       String?   @map("reply_to")
  bodyText      String?   @map("body_text")
  bodyHtml      String?   @map("body_html")
  headers       Json      @default("{}")
  riskScore     Int       @default(0) @map("risk_score")
  riskLevel     String    @default("low") @map("risk_level")
  signals       Json      @default("[]")
  status        String    @default("pending")
  source        String    @default("user_report")
  reportedAt    DateTime  @default(now()) @map("reported_at")
  reviewedAt    DateTime? @map("reviewed_at")
  reviewedBy    String?   @map("reviewed_by")
  adminNotes    String?   @map("admin_notes")

  organization Organization    @relation(fields: [orgId], references: [id])
  links        EmailLink[]
  attachments  EmailAttachment[]
  actions      AdminAction[]

  @@index([orgId])
  @@index([status])
  @@index([riskLevel])
  @@index([reportedAt(sort: Desc)])
  @@index([reviewedAt(sort: Desc)])
  @@index([senderDomain])
  @@index([status, reportedAt(sort: Desc)])
  @@index([orgId, status])
  @@map("email_reports")
}

model EmailLink {
  id          String  @id @default(cuid())
  reportId    String  @map("report_id")
  displayText String? @map("display_text")
  url         String?
  finalUrl    String? @map("final_url")
  domain      String?
  isSuspicious Boolean @default(false) @map("is_suspicious")
  riskReason  String? @map("risk_reason")

  report EmailReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("email_links")
}

model EmailAttachment {
  id           String  @id @default(cuid())
  reportId     String  @map("report_id")
  filename     String?
  contentType  String? @map("content_type")
  fileSize     Int?    @map("file_size")
  sha256       String?
  detectedType String? @map("detected_type")
  hasMacros    Boolean @default(false) @map("has_macros")
  vtPositives  Int?    @map("vt_positives")
  vtTotal      Int?    @map("vt_total")
  isSuspicious Boolean @default(false) @map("is_suspicious")
  riskReason   String? @map("risk_reason")

  report EmailReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("email_attachments")
}

model DomainList {
  id        String   @id @default(cuid())
  domain    String
  listType  String   @map("list_type")   // "whitelist" | "blacklist"
  source    String   @default("manual")  // "manual" | "openphish" | "phishtank"
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([domain, listType])
  @@map("domain_lists")
}

model AdminAction {
  id        String   @id @default(cuid())
  reportId  String   @map("report_id")
  adminId   String   @map("admin_id")
  action    String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  report EmailReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  admin  User        @relation(fields: [adminId], references: [id])

  @@map("admin_actions")
}

model MlModel {
  id          String   @id @default(cuid())
  name        String   @unique             // e.g. "phishing-naive-bayes"
  data        Json                          // ModelData JSON blob
  version     Int      @default(1)
  trainedOn   Int      @default(0) @map("trained_on")  // total examples trained
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("ml_models")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  userEmail  String?  @map("user_email")
  action     String                          // e.g. "login", "report.review", "domain.add", "org.create", "mfa.enable"
  resource   String?                         // e.g. "report:clxyz123", "domain:evil.com"
  detail     String?                         // human-readable summary
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
